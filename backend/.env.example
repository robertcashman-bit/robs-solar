# Rob's Solar backend configuration
# Copy to .env and adjust values. Never commit .env.

APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-secret-key
DATABASE_URL=sqlite+aiosqlite:///./data/robs_solar.db

# Safety: start read-only. Set false only when ready for control writes.
READ_ONLY=true

# Modbus bridge adapter (HTTP sidecar, not direct serial)
MODBUS_BRIDGE_URL=
MODBUS_BRIDGE_TOKEN=

# Direct Modbus TCP (RS485-WiFi dongle on LAN port 502)
# Run: python backend/scripts/discover_modbus.py to find host
MODBUS_HOST=
MODBUS_PORT=502
MODBUS_SLAVE_ID=1
MODBUS_MAX_RETRIES=2
POLL_INTERVAL_LIVE_SECONDS=10
POLL_INTERVAL_ENERGY_SECONDS=60

# Adapter: simulator | sunsynk_connect | home_assistant | modbus_bridge | modbus_tcp
ADAPTER_MODE=simulator

# Octopus Energy (API key from octopus.energy dashboard — not your login password)
OCTOPUS_API_KEY=
OCTOPUS_ACCOUNT_NUMBER=
OCTOPUS_MPAN=
OCTOPUS_METER_SERIAL=
OCTOPUS_TARIFF=AGILE
OCTOPUS_REGION=C

# Solar forecast (London default; 16 E-W + 6 W panels)
FORECAST_LATITUDE=51.5074
FORECAST_LONGITUDE=-0.1278
PANEL_COUNT_EW=16
PANEL_COUNT_W=6
PANEL_WATTAGE=480

# Global write feature flag.
# adapters refuse to write unless this is true. Simulator writes are always safe.
ENABLE_LIVE_WRITES=false

# CORS origins (comma-separated)
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Seeded local users (passwords hashed on startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=change-me-viewer

# Rate limiting for write endpoints
RATE_LIMIT_WRITES_PER_MINUTE=10

# Polling defaults
DEFAULT_POLL_INTERVAL_SECONDS=5

# Metric sampling (read-only background task for analytics)
METRICS_SAMPLER_ENABLED=true
METRICS_SAMPLE_INTERVAL_SECONDS=60
METRICS_RETENTION_DAYS=90

# Default electricity tariff (GBP per kWh); editable by admin via PUT /tariff
TARIFF_IMPORT_RATE=0.28
TARIFF_EXPORT_RATE=0.15
TARIFF_CURRENCY=GBP

# Optional alert notifications
ALERT_WEBHOOK_URL=

# Sunsynk Connect / Connect Pro cloud adapter (PRIMARY live path).
# WARNING: The Sunsynk cloud HTTP API is community-inferred and UNVERIFIED.
# Reads are defensive; writes are unverified and double-gated by feature flags.
# Secrets stay on the backend only and are never logged.
# Primary Sunsynk Connect API host (matches www.sunsynk.net web app).
SUNSYNK_BASE_URL=https://api.sunsynk.net
SUNSYNK_USERNAME=
SUNSYNK_PASSWORD=
SUNSYNK_PLANT_ID=
SUNSYNK_INVERTER_SN=
# Set true ONLY if you accept the risk of attempting unverified live writes.
SUNSYNK_ENABLE_UNVERIFIED_WRITES=false
SUNSYNK_TIMEOUT_SECONDS=10
SUNSYNK_MAX_RETRIES=2

# Home Assistant adapter (secondary/optional; read/write when entity IDs verified)
HA_BASE_URL=
HA_TOKEN=
HA_ENTITY_PV_POWER=
HA_ENTITY_BATTERY_SOC=
HA_ENTITY_HOUSE_LOAD=
HA_ENTITY_GRID_IMPORT=
HA_ENTITY_GRID_EXPORT=
HA_ENTITY_INVERTER_MODE=
HA_ENTITY_INVERTER_STATUS=
HA_ENTITY_EXPORT_LIMIT=
HA_SERVICE_EXPORT_LIMIT=

# AI assistant (OpenAI). The key lives only on the backend and is never sent to
# the UI. The assistant is read-only: it proposes changes that an admin confirms,
# which then go through the audited /controls/* endpoints.
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_ENABLED=false
