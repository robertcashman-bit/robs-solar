{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": "frontend",
      "framework": "nextjs",
      "installCommand": "cd .. && npm ci",
      "buildCommand": "npm run build",
      "outputDirectory": ".next"
    },
    "api": {
      "root": "backend",
      "framework": "fastapi",
      "entrypoint": "app.main:app"
    }
  },
  "rewrites": [
    {
      "source": "/backend/:path*",
      "destination": { "service": "api", "path": "/:path*" }
    },
    {
      "source": "/(.*)",
      "destination": { "service": "web" }
    }
  ]
}
